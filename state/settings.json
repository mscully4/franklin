{
  "name": "Franklin",
  "claude_bin": "claude",
  "mode": "allow_send",
  "timezone": "America/Chicago",
  "avatar": "Franklin.jpg",
  "user_profile": {
    "name": "Michael Scully",
    "discord_user_id": "475783212891897857",
    "tone": "curt but witty, with an air of mystery — says just enough to get the point across, leaves people wondering a little. Keeps it professional."
  },
  "authorized_users": [
    {
      "name": "michael-scully",
      "discord_user_id": "475783212891897857"
    },
    {
      "name": "catherine",
      "discord_user_id": "1506790929044869232"
    }
  ],
  "providers": {
    "anthropic": {
      "bin": "claude"
    },
    "deepseek": {
      "bin": "claude",
      "base_url": "https://api.deepseek.com/anthropic",
      "env": {
        "ANTHROPIC_API_KEY": "$DEEPSEEK_API_KEY",
        "ANTHROPIC_MODEL": "deepseek-v4-pro",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek-v4-pro",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-pro",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-flash",
        "CLAUDE_CODE_SUBAGENT_MODEL": "deepseek-v4-flash"
      }
    }
  },
  "default_provider": "anthropic",
  "provider_strategy": [
    {
      "provider": "anthropic",
      "fallback_when": {
        "quota_5h_gte": 75,
        "quota_7d_gte": 85
      }
    },
    {
      "provider": "deepseek"
    }
  ],
"feature_flags": {
    "skip_docker": true
  },
  "integrations": [
    "discord",
    {
      "name": "gws",
      "bin": "gws",
      "description": "Google Workspace CLI",
      "healthCheck": {"command": "gws auth status"}
    },
    {
      "name": "mmoney",
      "bin": "mmoney",
      "description": "Monarch Money finance CLI",
      "skillLocation": "./skills/mmoney",
      "healthCheck": {"command": "mmoney auth status"}
    },
    {
      "name": "agent-browser",
      "bin": "agent-browser",
      "description": "Browser automation CLI",
      "skillLocation": "./skills/agent-browser-cloak",
      "healthCheck": {"command": "curl -sf http://localhost:9222/json/version", "expect": "\"Browser\""}
    },
    {
      "name": "hassio",
      "bin": "hass-cli",
      "description": "Home Assistant smart home CLI",
      "env": [
        "HASSIO_URL",
        "HASSIO_TOKEN",
        "HASS_SERVER",
        "HASS_TOKEN"
      ],
      "skillLocation": "./skills/hassio",
      "healthCheck": {"command": "hass-cli config release", "expect": "[0-9]+\\.[0-9]+"}
    },
    {
      "name": "immich",
      "bin": "immich",
      "description": "Immich self-hosted photo/video management CLI",
      "env": [
        "IMMICH_SERVER",
        "IMMICH_API_KEY"
      ],
      "skillLocation": "./skills/immich"
    },
    {
      "name": "openscad",
      "bin": "openscad",
      "description": "OpenSCAD 3D CAD modeler CLI"
    },
    {
      "name": "google-health",
      "description": "Google Health API (Fitbit data via HTTP)",
      "skillLocation": "./skills/google-health",
      "env": [
        "GOOGLE_HEALTH_CLIENT_ID",
        "GOOGLE_HEALTH_CLIENT_SECRET",
        "GOOGLE_HEALTH_REFRESH_TOKEN"
      ]
    },
    {
      "name": "calibre",
      "bin": "calibredb",
      "description": "Calibre e-book library and Kindle email delivery",
      "skillLocation": "./skills/calibre",
      "healthCheck": {"command": "calibredb --library-path=$HOME/calibre-library list --limit 1", "notExpect": "Error|Traceback"}
    }
  ],
  "disabled_scouts": [
    "gmail",
    "calendar"
  ],
  "webhook": {
    "port": 9001,
    "ws_dir": "/usr/local/lib/franklin/ws",
    "github_owner": "mscully4",
    "repos": [
      { "github": "Mothership", "local": "mothership" },
      { "github": "poly-ball", "local": "poly-ball" },
      { "github": "cad-projects", "local": "cad-projects" }
    ]
  }
}